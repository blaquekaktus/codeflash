# Line endings — normalize to LF except Windows-specific scripts
* text=auto eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.mp3 binary
*.mp4 binary
*.mov binary
*.wav binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# Generated / vendored — suppress diffs and language stats
package-lock.json linguist-generated
yarn.lock linguist-generated
pnpm-lock.yaml linguist-generated
poetry.lock linguist-generated
Pipfile.lock linguist-generated
*.lock linguist-generated
